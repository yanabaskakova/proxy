# HTTP port the server listens on
PORT=3000

# Delay between streamed chunks, in milliseconds.
# NOTE: the spec default is 30000 (30s) — lower it (e.g. 50) for snappy local testing.
STREAM_DELAY_MS=30000

# Number of characters per streamed chunk (non-code paragraphs only).
STREAM_CHUNK_SIZE=100

# Returned when no rule matches the prompt.
DEFAULT_RESPONSE=No matching response found.

# Path to the JSON file containing the response rules (hot-reloaded on change).
RESPONSES_FILE=./responses.json

# Log incoming requests (true/false).
LOG_REQUESTS=true

# Mandatory bearer token required on every chat request.
# Clients must send: Authorization: Bearer <AUTH_TOKEN>
# If unset, all chat requests are rejected (fail closed).
AUTH_TOKEN=
